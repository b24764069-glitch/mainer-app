<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>MAINER PRO</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <script src="https://unpkg.com/@tonconnect/ui@latest/dist/tonconnect-ui.min.js"></script>
    <style>
        :root {
            --bg-color: #000000;
            --card-bg: #1c1c1e;
            --accent-color: #0a84ff;
            --success-color: #30d158;
            --text-color: #f5f5f7;
            --text-secondary: #86868b;
        }

        body { font-family: -apple-system, sans-serif; background-color: var(--bg-color); color: var(--text-color); margin: 0; overflow: hidden; height: 100vh; touch-action: none; }
        
        .miner-btn {
            width: 220px; height: 220px; background: radial-gradient(circle, #3498db, #2980b9);
            border-radius: 50%; display: flex; justify-content: center; align-items: center;
            font-size: 70px; cursor: pointer; transition: transform 0.1s;
            box-shadow: 0 0 30px rgba(10, 132, 255, 0.3);
            margin: 40px auto;
        }

        /* انیمیشن لرزش هنگام کلیک */
        .shake { animation: shake 0.2s ease-in-out; }
        @keyframes shake {
            0% { transform: translate(1px, 1px) rotate(0deg); }
            25% { transform: translate(-2px, -2px) rotate(-2deg); }
            50% { transform: translate(2px, 2px) rotate(2deg); }
            100% { transform: translate(0, 0) rotate(0deg); }
        }

        .btn-upgrade:disabled { opacity: 0.3; cursor: not-allowed; }
        .tab-bar-container { position: fixed; bottom: 20px; left: 10px; right: 10px; background: rgba(28, 28, 30, 0.9); backdrop-filter: blur(20px); border-radius: 25px; display: flex; padding: 10px; z-index: 100; }
        .page { display: none; height: 100vh; padding: 20px; overflow-y: auto; }
        .page.active { display: block; }
    </style>
</head>
<body>

    <div id="tab-home" class="page active">
        <div class="coin-balance" style="text-align: center; font-size: 40px; margin-top: 20px;">
            <span id="balance-display">0</span> 🪙
        </div>
        <div class="miner-btn" id="target-clicker">⛏️</div>
    </div>

    <!-- سایر بخش‌های صفحه (Level, Auto, و...) مشابه قبل -->
    
    <script>
        const tg = window.Telegram.WebApp;
        tg.expand();
        tg.enableClosingConfirmation();

        let state = { balance: 0, clickPower: 1, upgrades: { cpu: 0, gpu: 0, ram: 0 } };

        // سیستم کلیک بهبود یافته
        const clicker = document.getElementById('target-clicker');
        clicker.addEventListener('pointerdown', (e) => {
            e.preventDefault();
            
            // ثبت امتیاز
            state.balance += state.clickPower;
            updateDisplay();

            // اعمال انیمیشن
            clicker.classList.remove('shake');
            void clicker.offsetWidth; // ریست کردن انیمیشن
            clicker.classList.add('shake');

            // بازخورد لمسی (Haptic)
            if (tg.HapticFeedback) tg.HapticFeedback.impactOccurred('light');
        });

        function updateDisplay() {
            document.getElementById('balance-display').innerText = Math.floor(state.balance).toLocaleString();
            checkUpgradeButtons();
        }

        function checkUpgradeButtons() {
            document.querySelectorAll('.btn-upgrade').forEach(btn => {
                const cost = parseInt(btn.querySelector('span').innerText.replace(/,/g, ''));
                btn.disabled = state.balance < cost;
            });
        }

        // ذخیره‌سازی خودکار هر ۵ ثانیه
        setInterval(saveState, 5000);
        function saveState() {
            localStorage.setItem('game_save', JSON.stringify(state));
        }

        // اجرای اولیه
        const saved = localStorage.getItem('game_save');
        if(saved) state = JSON.parse(saved);
        updateDisplay();
    </script>
</body>
</html>
