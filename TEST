<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>توسعه‌یافته | مینی اپلیکیشن رمزارز تلگرام</title>
    <!-- Telegram Official WebApp SDK -->
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <!-- Official TON Connect SDK -->
    <script src="https://unpkg.com/@tonconnect/ui@latest/dist/tonconnect-ui.min.js"></script>
    <style>
        :root {
            --bg-color: #0c0c0e;
            --card-bg: #1a1a1c;
            --accent-color: #007aff;
            --success-color: #34c759;
            --text-color: #ffffff;
            --text-secondary: #8e8e93;
            --radius-card: 20px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            user-select: none;
            -webkit-user-select: none;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            overflow: hidden;
            height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .page {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            padding-bottom: 130px;
            display: none;
            width: 100%;
        }

        .page.active {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* داک پایین صفحه (تب‌بار) */
        .tab-bar-container {
            position: fixed;
            bottom: 20px;
            left: 20px;
            right: 20px;
            height: 75px;
            background-color: rgba(26, 26, 28, 0.85);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border-radius: 30px;
            display: flex;
            justify-content: space-around;
            align-items: center;
            padding: 0 10px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.5);
            z-index: 1000;
        }

        .tab-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: var(--text-secondary);
            font-size: 11px;
            font-weight: 500;
            cursor: pointer;
            flex: 1;
            transition: all 0.3s;
            border-radius: 20px;
            padding: 8px 0;
        }

        .tab-item.active {
            color: var(--accent-color);
            transform: scale(1.05);
        }

        .tab-icon {
            font-size: 22px;
            margin-bottom: 4px;
        }

        .card {
            width: 100%;
            background: var(--card-bg);
            padding: 20px;
            border-radius: var(--radius-card);
            margin-bottom: 16px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

        .coin-balance {
            font-size: 44px;
            font-weight: 800;
            margin: 15px 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* استایل کارت گرافیک اتوماینینگ در هوم */
        .gpu-mining-card {
            background: linear-gradient(135deg, #1c1c1e, #2c2c2e);
            border: 2px solid var(--accent-color);
            text-align: center;
            padding: 25px;
            border-radius: 24px;
            width: 100%;
            max-width: 340px;
            margin: 10px auto;
            box-shadow: 0 10px 30px rgba(0, 122, 255, 0.2);
        }

        .gpu-icon {
            font-size: 80px;
            margin-bottom: 15px;
            animation: pulseGpu 2s infinite;
        }

        @keyframes pulseGpu {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }

        .btn-action {
            width: 100%;
            background: var(--accent-color);
            color: white;
            border: none;
            padding: 14px;
            border-radius: 14px;
            font-size: 15px;
            font-weight: bold;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.1s;
        }

        .btn-action:active {
            transform: scale(0.98);
            opacity: 0.9;
        }

        .profile-field-group {
            margin-bottom: 15px;
            text-align: right;
        }

        .profile-field-group label {
            font-size: 12px;
            color: var(--text-secondary);
            display: block;
            margin-bottom: 5px;
        }

        .profile-field-group input {
            width: 100%;
            padding: 12px;
            background: #000;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 10px;
            color: #fff;
            font-size: 15px;
            outline: none;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
            font-size: 14px;
            padding-bottom: 8px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .info-row span:first-child {
            color: var(--text-secondary);
        }

        .upgrade-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            padding-bottom: 15px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .btn-upgrade {
            background: rgba(10, 132, 255, 0.2);
            color: var(--accent-color);
            border: none;
            padding: 8px 16px;
            border-radius: 15px;
            font-weight: bold;
            cursor: pointer;
        }
    </style>
</head>
<body>

    <!-- تب اول: هوم و اتوماینینگ کارت گرافیکی -->
    <div id="tab-home" class="page active">
        <div class="card" style="display:flex; justify-content:space-between; align-items:center;">
            <div>
                <span style="color: var(--text-secondary); font-size: 12px;">کاربر گرامی:</span><br>
                <strong id="home-username" style="font-size: 16px;">بارگذاری...</strong>
            </div>
            <div style="text-align: left;">
                <span style="color: var(--success-color); font-weight: bold;" id="active-coin-symbol">COIN</span>
            </div>
        </div>

        <div class="coin-balance">
            <span id="balance-display">0</span>
            <span id="coin-symbol-display">🪙</span>
        </div>

        <!-- بخش اتوماینینگ با عکس کارت گرافیک و دکمه استارت/توقف -->
        <div class="gpu-mining-card">
            <div class="gpu-icon">🎴</div>
            <h3 style="margin-bottom: 8px;">معدن‌کاوی خودکار (Auto Mining)</h3>
            <p id="mining-status-text" style="font-size: 12px; color: var(--text-secondary); margin-bottom: 15px;">وضعیت: متوقف شده</p>
            <button class="btn-action" id="toggle-mining-btn" onclick="toggleAutoMining()">شروع استخراج خودکار ⚡</button>
        </div>
    </div>

    <!-- تب دوم: ارتقای سخت‌افزار (Level) -->
    <div id="tab-level" class="page">
        <h2 style="margin-bottom: 20px; font-weight: 800; align-self: flex-start;">ارتقای سخت‌افزار</h2>
        <div class="card">
            <div class="upgrade-row">
                <div>
                    <h4>پردازنده (CPU)</h4>
                    <span style="font-size: 12px; color: var(--text-secondary);">سطح: <span id="lvl-cpu">0</span> (+1 سرعت)</span>
                </div>
                <button class="btn-upgrade" onclick="purchaseHardware('cpu')"><span id="cost-cpu">50</span></button>
            </div>
            <div class="upgrade-row">
                <div>
                    <h4>کارت گرافیک (GPU)</h4>
                    <span style="font-size: 12px; color: var(--text-secondary);">سطح: <span id="lvl-gpu">0</span> (+1 سرعت)</span>
                </div>
                <button class="btn-upgrade" onclick="purchaseHardware('gpu')"><span id="cost-gpu">100</span></button>
            </div>
            <div class="upgrade-row">
                <div>
                    <h4>حافظه رم (RAM)</h4>
                    <span style="font-size: 12px; color: var(--text-secondary);">سطح: <span id="lvl-ram">0</span> (+1 سرعت)</span>
                </div>
                <button class="btn-upgrade" onclick="purchaseHardware('ram')"><span id="cost-ram">150</span></button>
            </div>
        </div>
    </div>

    <!-- تب سوم: دوستان و دعوت -->
    <div id="tab-friend" class="page">
        <h2 style="margin-bottom: 20px; font-weight: 800; align-self: flex-start;">دعوت از دوستان</h2>
        <div class="card">
            <p style="font-size: 14px; color: var(--text-secondary); margin-bottom: 10px;">با دعوت هر دوست، پاداش بگیرید:</p>
            <div id="share-link" style="background:#000; padding:12px; border-radius:10px; font-family:monospace; font-size:12px; color:var(--success-color); word-break:break-all; margin-bottom:12px;">در حال دریافت لینک...</div>
            <button class="btn-action" onclick="copyReferral()">کپی لینک دعوت</button>
        </div>
    </div>

    <!-- تب چهارم: پروفایل، ساخت ارز و اتصال به ولت -->
    <div id="tab-profile" class="page">
        <h2 style="margin-bottom: 20px; font-weight: 800; align-self: flex-start;">پروفایل و تنظیمات ارز</h2>
        
        <!-- اطلاعات حساب تلگرام -->
        <div class="card">
            <h3 style="color: var(--accent-color); margin-bottom: 12px; font-size: 15px;">اطلاعات اکانت تلگرام</h3>
            <div class="info-row">
                <span>نام کاربر:</span>
                <strong id="prof-name">-</strong>
            </div>
            <div class="info-row">
                <span>یوزرنیم:</span>
                <strong id="prof-username">-</strong>
            </div>
            <div class="info-row" style="border-bottom: none; margin-bottom: 0;">
                <span>آیدی عددی (UID):</span>
                <strong id="prof-id" style="font-family: monospace;">-</strong>
            </div>
        </div>

        <!-- بخش ساخت و انتخاب ارز دیجیتال دلخواه -->
        <div class="card">
            <h3 style="color: var(--success-color); margin-bottom: 12px; font-size: 15px;">ساخت ارز دیجیتال جدید</h3>
            <div class="profile-field-group">
                <label>نام کامل ارز:</label>
                <input type="text" id="custom-token-name" placeholder="مثلا: MyCoin" oninput="saveCustomToken()">
            </div>
            <div class="profile-field-group" style="margin-bottom: 0;">
                <label>نماد ارز (سنبل/اموجی):</label>
                <input type="text" id="custom-token-symbol" placeholder="مثلا: 💎 یا MCN" oninput="saveCustomToken()">
            </div>
        </div>

        <!-- اتصال سریع ولت به پنل تلگرام -->
        <div class="card" style="border: 1px solid rgba(52, 209, 88, 0.3);">
            <h3 style="text-align: center; color: var(--success-color); margin-bottom: 15px; font-size: 15px;">اتصال سریع کیف پول (TON Connect)</h3>
            <div id="connect-wallet-btn" style="display: flex; justify-content: center;"></div>
            <div id="wallet-info-box" style="display: none; margin-top: 15px; font-size: 12px; word-break: break-all; background: #000; padding: 10px; border-radius: 8px; color: var(--success-color);"></div>
        </div>
    </div>

    <!-- نوار ناوبری پایین (تب‌بار) -->
    <div class="tab-bar-container">
        <div class="tab-item active" onclick="switchTab('tab-home', this)">
            <div class="tab-icon">🏠</div>
            <div>هوم</div>
        </div>
        <div class="tab-item" onclick="switchTab('tab-level', this)">
            <div class="tab-icon">🚀</div>
            <div>سطح</div>
        </div>
        <div class="tab-item" onclick="switchTab('tab-friend', this)">
            <div class="tab-icon">👥</div>
            <div>دوستان</div>
        </div>
        <div class="tab-item" onclick="switchTab('tab-profile', this)">
            <div class="tab-icon">⚙️</div>
            <div>پروفایل</div>
        </div>
    </div>

    <script>
        // راه‌اندازی اولیه وب‌اپ تلگرام
        const tg = window.Telegram.WebApp;
        tg.ready();
        tg.expand();

        // دریافت اطلاعات کاربر تلگرام
        const tgUser = tg.initDataUnsafe?.user || {
            id: 987654321,
            first_name: "کاربر تستی",
            username: "test_user"
        };

        // ذخیره‌سازی محلی پیشرفته امن
        const STORAGE_KEY = `crypto_miner_state_${tgUser.id}`;
        
        let state = {
            balance: 0,
            miningSpeed: 1,
            isMiningActive: false,
            tokenName: "MyCoin",
            tokenSymbol: "🪙",
            upgrades: {
                cpu: { level: 0, cost: 50 },
                gpu: { level: 0, cost: 100 },
                ram: { level: 0, cost: 150 }
            }
        };

        if (localStorage.getItem(STORAGE_KEY)) {
            try {
                state = JSON.parse(localStorage.getItem(STORAGE_KEY));
            } catch (e) {
                console.error("خطا در بارگذاری داده‌ها");
            }
        }

        // مقداردهی اولیه اطلاعات پروفایل تلگرام در DOM
        document.getElementById('home-username').innerText = tgUser.first_name;
        document.getElementById('prof-name').innerText = tgUser.first_name;
        document.getElementById('prof-username').innerText = tgUser.username ? `@${tgUser.username}` : 'ندارد';
        document.getElementById('prof-id').innerText = tgUser.id;
        document.getElementById('share-link').innerText = `https://t.me/YourBotName?start=ref_${tgUser.id}`;

        // مقداردهی فیلدهای ارز سفارشی
        document.getElementById('custom-token-name').value = state.tokenName;
        document.getElementById('custom-token-symbol').value = state.tokenSymbol;

        // اتصال سریع ولت TON Connect
        const tonConnectUI = new TONConnectUI.TonConnectUI({
            manifestUrl: 'https://raw.githubusercontent.com/ton-community/tonconnect-manifest/main/tonconnect-manifest.json',
            buttonRootId: 'connect-wallet-btn'
        });

        tonConnectUI.onStatusChange(wallet => {
            const walletBox = document.getElementById('wallet-info-box');
            if (wallet) {
                walletBox.style.display = 'block';
                walletBox.innerText = `متصل شد: ${wallet.account.address}`;
            } else {
                walletBox.style.display = 'none';
            }
        });

        // به‌روزرسانی ظاهر صفحه
        function updateUI() {
            document.getElementById('balance-display').innerText = Math.floor(state.balance).toLocaleString('en-US');
            document.getElementById('coin-symbol-display').innerText = state.tokenSymbol;
            document.getElementById('active-coin-symbol').innerText = state.tokenName;

            // سطح‌بندی‌ها
            document.getElementById('lvl-cpu').innerText = state.upgrades.cpu.level;
            document.getElementById('cost-cpu').innerText = state.upgrades.cpu.cost;
            document.getElementById('lvl-gpu').innerText = state.upgrades.gpu.level;
            document.getElementById('cost-gpu').innerText = state.upgrades.gpu.cost;
            document.getElementById('lvl-ram').innerText = state.upgrades.ram.level;
            document.getElementById('cost-ram').innerText = state.upgrades.ram.cost;

            // وضعیت دکمه استخراج خودکار
            const miningBtn = document.getElementById('toggle-mining-btn');
            const statusText = document.getElementById('mining-status-text');
            if (state.isMiningActive) {
                miningBtn.innerText = "توقف استخراج ⏸️";
                miningBtn.style.background = "#ff3b30";
                statusText.innerText = "وضعیت: در حال استخراج خودکار فعال... 🚀";
            } else {
                miningBtn.innerText = "شروع استخراج خودکار ⚡";
                miningBtn.style.background = "var(--accent-color)";
                statusText.innerText = "وضعیت: متوقف شده";
            }
        }

        function saveState() {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
        }

        // عملکرد دکمه اتوماینینگ در صفحه هوم (با کارت گرافیک)
        function toggleAutoMining() {
            state.isMiningActive = !state.isMiningActive;
            saveState();
            updateUI();
            if (tg.HapticFeedback) tg.HapticFeedback.impactOccurred('medium');
        }

        // موتور جمع‌آوری امتیاز خودکار تا وقتی صفحه باز است
        setInterval(() => {
            if (state.isMiningActive) {
                // محاسبه سود بر اساس قدرت یا سطح سخت‌افزارها
                let gain = 1 + (state.upgrades.cpu.level + state.upgrades.gpu.level + state.upgrades.ram.level) * 0.5;
                state.balance += gain;
                saveState();
                if (document.getElementById('tab-home').classList.contains('active')) {
                    document.getElementById('balance-display').innerText = Math.floor(state.balance).toLocaleString('en-US');
                }
            }
        }, 1000);

        // خرید ارتقاء سخت‌افزار
        function purchaseHardware(type) {
            let item = state.upgrades[type];
            if (state.balance >= item.cost) {
                state.balance -= item.cost;
                item.level++;
                item.cost = Math.floor(item.cost * 1.5);
                state.miningSpeed += 1;
                saveState();
                updateUI();
                if (tg.HapticFeedback) tg.HapticFeedback.notificationOccurred('success');
            } else {
                if (tg.HapticFeedback) tg.HapticFeedback.notificationOccurred('error');
                tg.showAlert("موجودی کافی نیست!");
            }
        }

        // ذخیره تغییرات ارز دلخواه کاربر
        function saveCustomToken() {
            state.tokenName = document.getElementById('custom-token-name').value || "MyCoin";
            state.tokenSymbol = document.getElementById('custom-token-symbol').value || "🪙";
            saveState();
            updateUI();
        }

        function copyReferral() {
            navigator.clipboard.writeText(document.getElementById('share-link').innerText).then(() => {
                tg.showAlert("لینک دعوت کپی شد!");
            });
        }

        // جابجایی بین تب‌ها
        function switchTab(pageId, element) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));

            document.getElementById(pageId).classList.add('active');
            element.classList.add('active');
            if (tg.HapticFeedback) tg.HapticFeedback.selectionChanged();
        }

        // اجرای اولیه
        updateUI();
    </script>
</body>
</html>
